# =============================================================================
#  LiteLLM stack — copy to .env and fill in:  cp .env.example .env
#  (.env is gitignored — never commit real keys.)
# =============================================================================

# Master key clients use to authenticate to the proxy (sent as a Bearer token).
# Use a strong random value, e.g.  openssl rand -hex 24
# This MUST match `litellm_api_key` in the agents' .env at the repo root.
LITELLM_MASTER_KEY=sk-your-litellm-master-key

# Anthropic API key LiteLLM uses to call Claude models.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
