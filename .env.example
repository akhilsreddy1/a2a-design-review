# =============================================================================
#  .env.example — copy to .env and fill in your values
#
#    cp .env.example .env
#
#  Variable names match config/settings.py field names (lowercase).
#  pydantic-settings reads them case-insensitively.
# =============================================================================

# --- LiteLLM gateway (the ONLY hub — A2A registry + LLM proxy) ---------------
litellm_base_url=http://localhost:4000 # http://host.docker.internal:4000
litellm_api_key=your-litellm-master-key-here

# --- LLM model defaults used by agents/router --------------------------------
default_model=claude-opus-4-6
router_model=claude-opus-4-6

# --- Specialist agents (one port each) ---------------------------------------
agent_host=0.0.0.0
agent_public_host=host.docker.internal
developer_port=9101
security_port=9102
performance_port=9103
testing_port=9104
devops_port=9105
code_reviewer_port=9106

# --- Bridge (event bus + orchestration + React UI) ----------------------------
# The React UI is served by the bridge (api/server.py).
# Open the app at http://localhost:8080
bridge_url=http://localhost:8080

# --- Resilience tunables (defaults are sensible — uncomment to override) ------
# a2a_task_deadline=180.0
# llm_timeout=60.0
# llm_max_retries=3
# llm_retry_base_delay=0.5
# llm_retry_max_delay=8.0
# llm_retry_jitter=true
# llm_breaker_threshold=5
# llm_breaker_reset=30.0

# --- LiteLLM hub/registry timeouts -------------------------------------------
# litellm_hub_timeout=10.0
# litellm_register_timeout=15.0
# a2a_gateway_route_prefix=/v1/a2a
